NODE_ENV=test

# Skip type-checking during test compilation - tsc already type-checks the whole
# codebase in CI's build step, so this just avoids paying for it twice (esmock's
# cache-busted re-imports make ts-node/esm's default type-checking mode noticeably slow).
TS_NODE_TRANSPILE_ONLY=true

# Add this secret to the password store, since we need to use it in Ansible playbook (to trigger a
# pipeline run after the Borg backup of the property_boundaries DB)
SECRET=secret-key

# For ownerships + INSPIRE pipeline
GOV_API_URL=
GOV_API_KEY=
MAPBOX_GEOCODER_TOKEN=test-geocoder-token

# For backups
REMOTE_BACKUP_DESTINATION_PATH=
REMOTE_BACKUP_SSH_PORT=
MATRIX_WEBHOOK_URL=

MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=test-master-key
