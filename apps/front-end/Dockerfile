# syntax=docker/dockerfile:1

# Multi-stage build for the Land Explorer front-end: build the Vite/React SPA
# with Node+npm, then serve the static assets with Caddy.
# Modelled on mykomap-monolith/apps/front-end/Dockerfile. The API is always
# same-origin: Caddy proxies /api + the socket.io websocket to API_UPSTREAM -
# the back-end compose service by default, or another deployment's public URL
# (PR previews, which have no back-end of their own). See docs/deployment.md.

# Versions must be supplied. NODE_VERSION has no sane default - fail if unset.
ARG NODE_VERSION=nonesuch
ARG CADDY_VERSION=2.11

# ---- build stage ----
FROM node:${NODE_VERSION}-alpine AS build
WORKDIR /app
RUN apk add --no-cache git

COPY package.json package-lock.json .npmrc ./
RUN --mount=type=cache,target=/root/.npm npm ci
COPY . .

# All client-side config is baked into the bundle at build time (Vite). Required
# values use ${VAR?} so the build fails loudly if they're missing.
ARG VITE_OS_KEY
ARG VITE_GEOCODER_TOKEN
ARG VITE_MAPBOX_TOKEN
ARG VITE_OS_PLACES_KEY
ARG VITE_PAYMENTS_URL
ARG VITE_USER_GUIDE_URL
ARG VITE_MIXPANEL_TOKEN
ARG VITE_MIXPANEL_PEPPER
ENV VITE_OS_KEY=${VITE_OS_KEY?} \
    VITE_GEOCODER_TOKEN=${VITE_GEOCODER_TOKEN?} \
    VITE_MAPBOX_TOKEN=${VITE_MAPBOX_TOKEN?} \
    VITE_OS_PLACES_KEY=${VITE_OS_PLACES_KEY} \
    VITE_PAYMENTS_URL=${VITE_PAYMENTS_URL} \
    VITE_USER_GUIDE_URL=${VITE_USER_GUIDE_URL} \
    VITE_MIXPANEL_TOKEN=${VITE_MIXPANEL_TOKEN} \
    VITE_MIXPANEL_PEPPER=${VITE_MIXPANEL_PEPPER}
RUN npm run build

# ---- runtime stage ----
FROM caddy:${CADDY_VERSION}-alpine

# Caddy must know the hostname it should respond to; it's baked into the
# Caddyfile at build time (Caddy won't serve an unknown hostname). The site
# also answers *.<hostname> so PR previews (<pr>.dev.app...) are served by
# the same image.
ARG CADDY_HOSTNAME
ENV CADDY_HOSTNAME=${CADDY_HOSTNAME?}

# Where /api + /socket.io are proxied. Default = the back-end compose service.
# PR previews have no back-end in their stack, so they set the dev deployment's
# public URL (https://...) and ride its stack same-origin.
ARG API_UPSTREAM=back-end:4000

WORKDIR /usr/share/caddy/
COPY --from=build /app/dist/ .

# Generate the Caddyfile into the image. Single-site shorthand (no braces).
# handle blocks are mutually exclusive: /api and /socket.io go to API_UPSTREAM;
# everything else is the SPA, with try_files fallback so client-side routes
# work. try_files must NOT see /api paths - it would rewrite them to
# /index.html before the proxy runs. An https:// upstream (PR previews) needs
# the Host header rewritten to the upstream's, or the proxy in front of it
# routes the request back to us by preview hostname.
# No HTTPS here: an external reverse proxy (Coolify/Apache) terminates TLS.
RUN <<SCRIPT
set -e
if [ "${API_UPSTREAM#https://}" != "${API_UPSTREAM}" ]; then
	PROXY="reverse_proxy ${API_UPSTREAM} {
		header_up Host ${API_UPSTREAM#https://}
	}"
else
	PROXY="reverse_proxy ${API_UPSTREAM}"
fi
cat >/etc/caddy/Caddyfile <<EOF
# Autogenerated - see Dockerfile
${CADDY_HOSTNAME?}:80, *.${CADDY_HOSTNAME?}:80

encode gzip

handle /api/* {
	${PROXY}
}
handle /socket.io/* {
	${PROXY}
}
handle {
	root * /usr/share/caddy
	try_files {path} /index.html
	file_server
}
EOF
SCRIPT
